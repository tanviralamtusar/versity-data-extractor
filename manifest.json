{
  "manifest_version": 3,
  "name": "API Extractor",
  "version": "1.0.0",
  "description": "Collect and display all API requests from any website",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://studentportal.green.edu.bd/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://studentportal.green.edu.bd/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://studentportal.green.edu.bd/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "API Extractor",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
